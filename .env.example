# Server
PORT=3000

# GitHub OAuth App credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Jira OAuth 2.0 (3LO) credentials
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# AI / LLM (optional — set endpoint and model here or in settings UI)
LLM_ENDPOINT=
LLM_MODEL=
LLM_API_KEY=

# Encryption key (optional — auto-generated on first run if not set)
ENCRYPTION_KEY=

# Data retention (days, optional — defaults shown)
RETENTION_TODOS_DAYS=7
RETENTION_WORK_ITEMS_DAYS=14
